{
  "name": "seukku",
  "main": "worker.js",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    // /s/{slug} 는 worker가 먼저 처리 → index.html에 스티커별 OG 주입 (카톡·네이버 미리보기)
    "run_worker_first": ["/s/*"],
    // 자산에 없는 그 외 경로는 무조건 index.html 반환 → 새로고침/딥링크 흰 화면(빈 404) 방지
    "not_found_handling": "single-page-application"
  }
}
