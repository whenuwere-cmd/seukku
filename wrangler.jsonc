{
  "name": "seukku",
  "main": "worker.js",
  "compatibility_date": "2025-01-01",
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    // 자산에 없는 경로(/s/{slug} 새로고침·딥링크)는 index.html 반환 → 흰 화면(빈 404) 방지.
    // compatibility_date가 2025-04-01 미만이라 /s/ 진입은 여전히 worker를 거쳐 OG가 주입됨.
    "not_found_handling": "single-page-application"
  }
}
